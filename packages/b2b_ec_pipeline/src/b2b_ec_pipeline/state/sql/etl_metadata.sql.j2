CREATE SCHEMA IF NOT EXISTS {{ schema }};

CREATE TABLE IF NOT EXISTS {{ schema }}.runs (
    run_id TEXT NOT NULL,
    source TEXT NOT NULL,
    dataset TEXT NOT NULL,
    stage TEXT NOT NULL,
    run_ts TIMESTAMPTZ NOT NULL,
    status TEXT NOT NULL CHECK (status IN ('started', 'completed', 'failed')),
    record_count BIGINT NOT NULL DEFAULT 0,
    bad_record_count BIGINT NOT NULL DEFAULT 0,
    watermark_before JSONB NOT NULL DEFAULT '{}'::jsonb,
    watermark_after JSONB NOT NULL DEFAULT '{}'::jsonb,
    started_at TIMESTAMPTZ,
    finished_at TIMESTAMPTZ,
    failed_at TIMESTAMPTZ,
    error_message TEXT,
    updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    PRIMARY KEY (run_id, source, dataset, stage)
);

CREATE TABLE IF NOT EXISTS {{ schema }}.run_paths (
    run_id TEXT NOT NULL,
    source TEXT NOT NULL,
    dataset TEXT NOT NULL,
    stage TEXT NOT NULL,
    path_kind TEXT NOT NULL CHECK (path_kind IN ('processed_file', 'raw_path', 'processed_path')),
    path_index INTEGER NOT NULL,
    path TEXT NOT NULL,
    updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    PRIMARY KEY (run_id, source, dataset, stage, path_kind, path_index),
    FOREIGN KEY (run_id, source, dataset, stage)
        REFERENCES {{ schema }}.runs (run_id, source, dataset, stage)
        ON DELETE CASCADE
);

CREATE TABLE IF NOT EXISTS {{ schema }}.watermarks (
    source TEXT NOT NULL,
    dataset TEXT NOT NULL,
    stage TEXT NOT NULL,
    mode TEXT,
    watermark_column TEXT,
    watermark_value JSONB,
    last_file TEXT,
    last_line INTEGER,
    processed_files_count INTEGER,
    run_id TEXT NOT NULL,
    updated_at TIMESTAMPTZ NOT NULL,
    PRIMARY KEY (source, dataset, stage)
);

CREATE TABLE IF NOT EXISTS {{ schema }}.checkpoints (
    run_id TEXT NOT NULL,
    source TEXT NOT NULL,
    dataset TEXT NOT NULL,
    stage TEXT NOT NULL,
    checkpoint_name TEXT NOT NULL,
    checkpoint_value JSONB,
    updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    PRIMARY KEY (run_id, source, dataset, stage, checkpoint_name),
    FOREIGN KEY (run_id, source, dataset, stage)
        REFERENCES {{ schema }}.runs (run_id, source, dataset, stage)
        ON DELETE CASCADE
);

CREATE TABLE IF NOT EXISTS {{ schema }}.schema_snapshots (
    run_id TEXT NOT NULL,
    source TEXT NOT NULL,
    dataset TEXT NOT NULL,
    stage TEXT NOT NULL,
    captured_at TIMESTAMPTZ NOT NULL,
    row_count BIGINT,
    updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    PRIMARY KEY (run_id, source, dataset, stage),
    FOREIGN KEY (run_id, source, dataset, stage)
        REFERENCES {{ schema }}.runs (run_id, source, dataset, stage)
        ON DELETE CASCADE
);

CREATE TABLE IF NOT EXISTS {{ schema }}.schema_snapshot_columns (
    run_id TEXT NOT NULL,
    source TEXT NOT NULL,
    dataset TEXT NOT NULL,
    stage TEXT NOT NULL,
    column_index INTEGER NOT NULL,
    name TEXT NOT NULL,
    dtype TEXT NOT NULL,
    nullable BOOLEAN NOT NULL DEFAULT TRUE,
    updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    PRIMARY KEY (run_id, source, dataset, stage, column_index),
    FOREIGN KEY (run_id, source, dataset, stage)
        REFERENCES {{ schema }}.schema_snapshots (run_id, source, dataset, stage)
        ON DELETE CASCADE
);

CREATE INDEX IF NOT EXISTS idx_runs_source_dataset_stage_status_updated
ON {{ schema }}.runs (source, dataset, stage, status, updated_at DESC);

CREATE INDEX IF NOT EXISTS idx_runs_run_id
ON {{ schema }}.runs (run_id);

CREATE INDEX IF NOT EXISTS idx_watermarks_source_dataset_stage_updated
ON {{ schema }}.watermarks (source, dataset, stage, updated_at DESC);

CREATE INDEX IF NOT EXISTS idx_checkpoints_source_dataset_stage_updated
ON {{ schema }}.checkpoints (source, dataset, stage, updated_at DESC);

CREATE INDEX IF NOT EXISTS idx_schema_snapshots_source_dataset_stage_updated
ON {{ schema }}.schema_snapshots (source, dataset, stage, captured_at DESC);
